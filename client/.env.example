# ──────────────────────────────────────────────────────────────────────
# ShufferC client (Expo) — environment variables (reference)
# Copy to client/.env and adjust. Only EXPO_PUBLIC_-prefixed vars are
# exposed to the client bundle. client/.env is git-ignored.
# ──────────────────────────────────────────────────────────────────────

# Base URL of the ShufferC REST API the client talks to.
EXPO_PUBLIC_API_URL=http://localhost:3000

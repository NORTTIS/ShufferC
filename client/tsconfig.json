{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-native",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": [
      "ESNext",
      "DOM"
    ],
    "types": [
      "react",
      "node"
    ],
    "noEmit": true
  },
  "include": [
    "src",
    "App.tsx",
    "index.ts",
    "../shared/types.ts",
    "../shared/backgrounds.ts"
  ],
  "exclude": [
    "src/**/*.test.ts"
  ],
  "extends": "expo/tsconfig.base"
}

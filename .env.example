# ──────────────────────────────────────────────────────────────────────
# ShufferC — environment variables (reference)
# Copy this file to `.env` and fill in real values. `.env` is git-ignored;
# this `.env.example` is committed as the canonical list of every variable.
# ──────────────────────────────────────────────────────────────────────

# ── Server (read only in server/config.ts) ─────────────────────────────

# HTTP port the REST API listens on.
PORT=3000

# Google Gemini API key. Leave BLANK to run without AI generation:
# the server still boots and serves pre-seeded routes, but
# POST /admin/routes/generate reports the provider as unavailable (503).
GEMINI_API_KEY=

# Gemini model ids (override only if you need different models).
# Pro = framework generation (slice C1). Flash = reserved for C3 live event-gen.
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash

# Embedding model for RAG (novel chunk vectors).
GEMINI_EMBED_MODEL=gemini-embedding-001

# Supabase Postgres connection string (Settings → Database → Connection string → URI).
# SECRET — never commit. Leave BLANK to run on in-memory stores (dev/test).
DATABASE_URL=

# Admin console credentials (local/academic only — NOT production auth).
ADMIN_EMAIL=adminshufferc@gmail.com
ADMIN_PASSWORD=admin12345678

# Supabase Auth (player register/login). Both empty → in-memory player auth.
# Project Settings → API: Project URL + anon public key.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Only needed for legacy projects that still sign JWTs with the shared secret (HS256).
# Leave empty for new projects (asymmetric keys verified via JWKS).
SUPABASE_JWT_SECRET=

# ── Client (Expo — read only in client/src/config.ts) ──────────────────
# Base URL the RN/Expo client calls. Must keep the EXPO_PUBLIC_ prefix so
# Expo injects it into the bundle. NOTE: Expo loads its own .env from the
# client/ directory, so for the client this belongs in client/.env
# (see client/.env.example). Listed here too for a single complete reference.
EXPO_PUBLIC_API_URL=http://localhost:3000
